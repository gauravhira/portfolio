# Password for the ops subdomain (ops.gauravhira.dev)
# Used as both the login password and the HMAC signing key for session tokens.
OPS_PASSWORD=change-me

# Supabase project used by the ops leads dashboard (server-side only, never exposed to the browser)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=change-me

# Zoho SMTP credentials used to send lead outreach emails (server-side only)
ZOHO_EMAIL=you@yourdomain.com
ZOHO_APP_PASSWORD=change-me

# Hunter.io API key used for the credits-remaining widget (free account endpoint, no credits consumed)
HUNTER_API_KEY=change-me
